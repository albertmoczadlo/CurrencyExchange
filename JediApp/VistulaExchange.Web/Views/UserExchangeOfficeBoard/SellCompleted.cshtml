
@{
    var currentSaldo = ViewData["currentSaldo"] is decimal saldo ? saldo : 0m;
    var currency = ViewData["currency"] as string ?? string.Empty;
}

<div style="width: 700px; font-weight: bold; text-align: center; margin: 100px auto;">
    <h1>Sell completed successfully</h1>
</div>

<h5>
    Your current saldo:
    <b>
        @(currentSaldo.ToString("0.00"))
        @currency
    </b>
</h5>
