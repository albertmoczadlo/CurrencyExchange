@model VistulaExchange.Web.Models.ExchangeBoardViewModel

@{
    ViewData["Title"] = Model.Title;
    var tightestSpread = Model.Currencies.OrderBy(a => a.Spread).FirstOrDefault();
}

<section class="desk-shell" data-board-shell>
    <div class="page-head">
        <div>
            <span class="page-head__eyebrow">Admin Trading Desk</span>
            <h1>@Model.Title</h1>
            <p>@Model.Subtitle</p>
        </div>
        <div class="page-head__summary">
            <div class="page-pill">
                <span>Visible pairs</span>
                <strong data-results-count>@Model.Currencies.Count</strong>
            </div>
            @if (tightestSpread != null)
            {
                <div class="page-pill">
                    <span>Tightest spread</span>
                    <strong>@tightestSpread.ShortName · @tightestSpread.Spread.ToString("0.0000")</strong>
                </div>
            }
        </div>
    </div>

    <div class="desk-toolbar">
        <form method="get" asp-action="Index" class="desk-search">
            <i class="bi bi-search"></i>
            <input type="text"
                   name="query"
                   value="@Model.SearchQuery"
                   placeholder="Filter by currency, code or country"
                   data-board-filter
                   aria-label="Filter currencies" />
        </form>

        <div class="desk-toolbar__actions">
            <a class="app-btn app-btn--ghost" asp-action="Create">Create currency</a>

            <form asp-action="AddCurrencyFromNbpApi" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="app-btn app-btn--ghost">Import NBP list</button>
            </form>

            <form asp-action="UpdateCurrencyRatesFromNbpApi" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="app-btn app-btn--primary">Refresh live rates</button>
            </form>

            <form asp-action="Markup" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="app-btn app-btn--ghost">Apply markup</button>
            </form>

            <a class="app-btn app-btn--ghost" asp-controller="AdminExchangeOfficeSettings" asp-action="Index">Desk settings</a>
        </div>
    </div>

    <div class="market-board-grid" data-board-grid>
        @foreach (var currency in Model.Currencies)
        {
            <article class="market-card"
                     data-market-card
                     data-market-name="@($"{currency.Name} {currency.ShortName} {currency.Country}")">
                <div class="market-card__top">
                    <div>
                        <span class="market-card__code">@currency.ShortName</span>
                        <h3>@currency.Name</h3>
                        <p>@currency.Country</p>
                    </div>
                    <span class="market-chip">@currency.SpreadProfile</span>
                </div>

                <dl class="market-card__stats">
                    <div>
                        <dt>Buy</dt>
                        <dd>@currency.BuyAt.ToString("0.0000")</dd>
                    </div>
                    <div>
                        <dt>Sell</dt>
                        <dd>@currency.SellAt.ToString("0.0000")</dd>
                    </div>
                    <div>
                        <dt>Spread</dt>
                        <dd>@currency.Spread.ToString("0.0000")</dd>
                    </div>
                </dl>

                <div class="market-card__actions">
                    <a class="market-card__action" asp-action="Details" asp-route-id="@currency.Id">Details</a>
                    <a class="market-card__action" asp-action="Edit" asp-route-id="@currency.Id">Edit</a>
                    <a class="market-card__action market-card__action--danger" asp-action="Delete" asp-route-id="@currency.Id">Delete</a>
                </div>
            </article>
        }
    </div>

    <div class="empty-state" data-empty-state @(Model.Currencies.Count == 0 ? string.Empty : "hidden")>
        <h2>No matching currencies</h2>
        <p>Try another query or import a fresh list from NBP to expand the board.</p>
    </div>
</section>
