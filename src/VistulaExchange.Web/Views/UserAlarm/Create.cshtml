@model VistulaExchange.Database.Domain.UserAlarm

@{
    ViewData["Title"] = "Create alert";
    var currencies = ViewData["currencies"] as IEnumerable<string> ?? Array.Empty<string>();
    var currencyRates = ViewData["currencyRates"] as string ?? "[]";
}

<section class="workspace-shell">
    <div class="page-head">
        <div>
            <span class="page-head__eyebrow">Alert Builder</span>
            <h1>Create a smart rate alert</h1>
            <p>Use direct targets or percentage presets to set up an alert without doing desk math manually.</p>
        </div>
    </div>

    <div class="trade-grid">
        <form asp-action="CreateAlarm"
              method="post"
              class="dashboard-card trade-form"
              data-alert-editor
              data-alert-rates='@Html.Raw(currencyRates)'>
            <div class="dashboard-card__head">
                <div>
                    <span class="page-head__eyebrow">Target Setup</span>
                    <h2>Thresholds</h2>
                </div>
            </div>

            <div class="trade-input-group">
                <label asp-for="ShortName">Currency</label>
                <select asp-for="ShortName" class="form-select" data-alert-code>
                    @foreach (var item in currencies)
                    {
                        <option value="@item">@item</option>
                    }
                </select>
            </div>

            <div class="trade-input-group">
                <label asp-for="AlarmBuyAt">Buy target</label>
                <input asp-for="AlarmBuyAt" class="form-control" type="number" step="0.0001" min="0" data-alert-buy />
                <small>Trigger when the desk buy rate falls to this level or lower.</small>
            </div>

            <div class="trade-input-group">
                <label asp-for="AlarmSellAt">Sell target</label>
                <input asp-for="AlarmSellAt" class="form-control" type="number" step="0.0001" min="0" data-alert-sell />
                <small>Trigger when the desk sell rate rises to this level or higher.</small>
            </div>

            <div class="trade-actions">
                <button type="submit" class="app-btn app-btn--primary">Save alert</button>
                <a class="app-btn app-btn--ghost" asp-action="Index">Back</a>
            </div>
        </form>

        <aside class="dashboard-card trade-summary">
            <div class="dashboard-card__head">
                <div>
                    <span class="page-head__eyebrow">Preset Assistant</span>
                    <h2>Quick presets</h2>
                </div>
            </div>

            <dl class="trade-summary__stats">
                <div>
                    <dt>Current buy</dt>
                    <dd data-alert-current-buy>0.0000</dd>
                </div>
                <div>
                    <dt>Current sell</dt>
                    <dd data-alert-current-sell>0.0000</dd>
                </div>
            </dl>

            <div class="preset-grid">
                <button type="button" class="preset-chip" data-alert-preset="buy" data-alert-percent="1">Buy dip 1%</button>
                <button type="button" class="preset-chip" data-alert-preset="buy" data-alert-percent="2">Buy dip 2%</button>
                <button type="button" class="preset-chip" data-alert-preset="sell" data-alert-percent="1">Sell spike 1%</button>
                <button type="button" class="preset-chip" data-alert-preset="sell" data-alert-percent="2">Sell spike 2%</button>
                <button type="button" class="preset-chip" data-alert-preset="sell" data-alert-percent="5">Sell spike 5%</button>
            </div>

            <p class="trade-summary__foot">Presets translate percentage moves into exact desk thresholds and drop them straight into the form.</p>
        </aside>
    </div>
</section>
