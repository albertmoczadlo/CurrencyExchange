@using VistulaExchange.Database.Domain;
@using Microsoft.AspNetCore.Identity

@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<ul class="app-auth">
@if (SignInManager.IsSignedIn(User))
{
    <li class="app-auth__item">
        <a id="manage" class="app-auth__link app-auth__link--ghost" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            <span class="app-auth__label">Desk Access</span>
            <strong>@UserManager.GetUserName(User)</strong>
        </a>
    </li>
    <li class="app-auth__item">
        <form id="logoutForm" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button id="logout" type="submit" class="app-auth__link app-auth__link--primary">Logout</button>
        </form>
    </li>
}
else
{
    <li class="app-auth__item">
        <a class="app-auth__link app-auth__link--ghost" id="register" asp-area="Identity" asp-page="/Account/Register">Create account</a>
    </li>
    <li class="app-auth__item">
        <a class="app-auth__link app-auth__link--primary" id="login" asp-area="Identity" asp-page="/Account/Login">Enter desk</a>
    </li>
}
</ul>
