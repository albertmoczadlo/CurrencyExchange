<!DOCTYPE html>
<html lang="en">
@{
    var pageTitle = ViewData["Title"] as string ?? "Vistula Exchange";
    string[] adminPages = { "User", "MoneyStock", "AdminExchange", "AdminTransactionHistory", "AdminReport", "AdminExchangeOfficeSettings" };
    string[] userPages = { "AccountBalance", "UserDeposit", "UserExchangeOfficeBoard", "UserWithdrawal", "UserTransactionHistory", "UserAlarm" };
    var activePage = ViewData["activePage"] as string ?? string.Empty;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole("Admin");
}
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@pageTitle - Vistula Exchange</title>
    <meta name="description" content="Modern foreign exchange workspace for tracking rates, simulating trades and managing your exchange desk." />

    <link href="~/img/favicon.png" rel="icon" />
    <link href="~/img/apple-touch-icon.png" rel="apple-touch-icon" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />

    <link href="~/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/vendor/bootstrap/css/bootstrap-utilities.css" rel="stylesheet" />
    <link href="~/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/vendor/boxicons/css/boxicons.min.css" rel="stylesheet" />
    <link href="~/vendor/quill/quill.snow.css" rel="stylesheet" />
    <link href="~/vendor/quill/quill.bubble.css" rel="stylesheet" />
    <link href="~/vendor/remixicon/remixicon.css" rel="stylesheet" />
    <link href="~/vendor/simple-datatables/style.css" rel="stylesheet" />

    <link href="~/css/style.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/rates.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VistulaExchange.Web.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <header id="header" class="header fixed-top app-header">
        <div class="app-header__left">
            <i class="bi bi-list toggle-sidebar-btn app-header__toggle"></i>
            <a asp-area="" asp-controller="Home" asp-action="Index" class="logo app-brand">
                <img src="~/img/logo.png" alt="Vistula Exchange">
                <span>Vistula Exchange</span>
            </a>
            <div class="app-header__descriptor">
                <span class="app-status-pill">Warsaw FX Workspace</span>
                <span class="app-status-pill app-status-pill--muted">Live board and role-based actions</span>
            </div>
        </div>

        <div class="app-header__right">
            <partial name="_LoginPartial" />
        </div>
    </header>

    <aside id="sidebar" class="sidebar app-sidebar">
        <div class="app-sidebar__panel">
            <div class="app-sidebar__eyebrow">Desk Access</div>
            <h2 class="app-sidebar__title">Move from market scan to action in one flow.</h2>
            <p class="app-sidebar__copy">
                @(isAdmin
                    ? "Refresh rates, steer markup and supervise the board from the same workspace."
                    : isAuthenticated
                        ? "Track your balance, set alarms and trade directly from the live desk."
                        : "Explore the live market view, then sign in to unlock your trading workspace.")
            </p>
        </div>

        <ul class="sidebar-nav" id="sidebar-nav">
            <li class="nav-item">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link @(activePage == "Home" || string.IsNullOrWhiteSpace(activePage) ? string.Empty : "collapsed")">
                    <i class="bi bi-stars"></i>
                    <span>Market Hub</span>
                </a>
            </li>

            @if (isAdmin)
            {
                <li class="nav-item">
                    <a class="nav-link @(adminPages.Contains(activePage) ? string.Empty : "collapsed")" data-bs-target="#admin-nav" data-bs-toggle="collapse" href="#">
                        <i class="bi bi-activity"></i>
                        <span>Admin Desk</span>
                        <i class="bi bi-chevron-down ms-auto"></i>
                    </a>
                    <ul id="admin-nav" class="nav-content collapse @(adminPages.Contains(activePage) ? "show" : string.Empty)" data-bs-parent="#sidebar-nav">
                        <li>
                            <a class="@(activePage == "AdminExchange" ? "active" : string.Empty)" asp-area="" asp-controller="ExchangeOfficeBoard" asp-action="Index">
                                <i class="bi bi-circle-fill"></i>
                                <span>Trading Desk</span>
                            </a>
                        </li>
                        <li>
                            <a class="@(activePage == "MoneyStock" ? "active" : string.Empty)" asp-area="" asp-controller="MoneyStock" asp-action="Index">
                                <i class="bi bi-circle-fill"></i>
                                <span>Liquidity</span>
                            </a>
                        </li>
                        <li>
                            <a class="@(activePage == "User" ? "active" : string.Empty)" asp-area="" asp-controller="User" asp-action="Index">
                                <i class="bi bi-circle-fill"></i>
                                <span>Clients</span>
                            </a>
                        </li>
                        <li>
                            <a class="@(activePage == "AdminTransactionHistory" ? "active" : string.Empty)" asp-area="" asp-controller="AdminTransactionHistory" asp-action="Index">
                                <i class="bi bi-circle-fill"></i>
                                <span>Transactions</span>
                            </a>
                        </li>
                        <li>
                            <a class="@(activePage == "AdminReport" ? "active" : string.Empty)" asp-area="" asp-controller="AdminReport" asp-action="Index">
                                <i class="bi bi-circle-fill"></i>
                                <span>Reports</span>
                            </a>
                        </li>
                        <li>
                            <a class="@(activePage == "AdminExchangeOfficeSettings" ? "active" : string.Empty)" asp-area="" asp-controller="AdminExchangeOfficeSettings" asp-action="Index">
                                <i class="bi bi-circle-fill"></i>
                                <span>Desk Settings</span>
                            </a>
                        </li>
                    </ul>
                </li>
            }

            @if (isAuthenticated && !isAdmin)
            {
                <li class="nav-item">
                    <a class="nav-link @(userPages.Contains(activePage) ? string.Empty : "collapsed")" data-bs-target="#user-nav" data-bs-toggle="collapse" href="#">
                        <i class="bi bi-wallet2"></i>
                        <span>Client Wallet</span>
                        <i class="bi bi-chevron-down ms-auto"></i>
                    </a>
                    <ul id="user-nav" class="nav-content collapse @(userPages.Contains(activePage) ? "show" : string.Empty)" data-bs-parent="#sidebar-nav">
                        <li>
                            <a class="@(activePage == "UserExchangeOfficeBoard" ? "active" : string.Empty)" asp-area="" asp-controller="UserExchangeOfficeBoard" asp-action="Index">
                                <i class="bi bi-circle-fill"></i>
                                <span>Live Exchange</span>
                            </a>
                        </li>
                        <li>
                            <a class="@(activePage == "AccountBalance" ? "active" : string.Empty)" asp-area="" asp-controller="UserAccountBalance" asp-action="Index">
                                <i class="bi bi-circle-fill"></i>
                                <span>Portfolio Hub</span>
                            </a>
                        </li>
                        <li>
                            <a class="@(activePage == "UserDeposit" ? "active" : string.Empty)" asp-area="" asp-controller="UserDeposit" asp-action="Index">
                                <i class="bi bi-circle-fill"></i>
                                <span>Deposit</span>
                            </a>
                        </li>
                        <li>
                            <a class="@(activePage == "UserWithdrawal" ? "active" : string.Empty)" asp-area="" asp-controller="UserWithdrawal" asp-action="Index">
                                <i class="bi bi-circle-fill"></i>
                                <span>Withdrawal</span>
                            </a>
                        </li>
                        <li>
                            <a class="@(activePage == "UserTransactionHistory" ? "active" : string.Empty)" asp-area="" asp-controller="UserTransactionHistory" asp-action="Index">
                                <i class="bi bi-circle-fill"></i>
                                <span>History</span>
                            </a>
                        </li>
                        <li>
                            <a class="@(activePage == "UserAlarm" ? "active" : string.Empty)" asp-area="" asp-controller="UserAlarm" asp-action="Index">
                                <i class="bi bi-circle-fill"></i>
                                <span>Rate Alerts</span>
                            </a>
                        </li>
                    </ul>
                </li>
            }
        </ul>
    </aside>

    <main id="main" class="main app-main">
        @RenderBody()
    </main>

    <a href="#" class="back-to-top d-flex align-items-center justify-content-center">
        <i class="bi bi-arrow-up-short"></i>
    </a>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/vendor/apexcharts/apexcharts.min.js"></script>
    <script src="~/vendor/chart.js/chart.min.js"></script>
    <script src="~/vendor/echarts/echarts.min.js"></script>
    <script src="~/vendor/quill/quill.min.js"></script>
    <script src="~/vendor/simple-datatables/simple-datatables.js"></script>
    <script src="~/vendor/tinymce/tinymce.min.js"></script>
    <script src="~/vendor/php-email-form/validate.js"></script>
    <script src="~/js/main.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
