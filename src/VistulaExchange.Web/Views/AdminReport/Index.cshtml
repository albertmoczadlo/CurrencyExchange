@model VistulaExchange.Services.Models.AdminDashboardDto
@using System.Text.Json

@{
    ViewData["Title"] = "Admin Command Center";
    var activityJson = JsonSerializer.Serialize(Model.MonthlyActivity.Select(point => new { label = point.Label, value = point.Value }));
    var turnoverJson = JsonSerializer.Serialize(Model.Turnovers.Select(item => new { code = item.CurrencyCode, value = item.Amount }));
}

<section class="workspace-shell"
         data-admin-dashboard
         data-admin-activity='@Html.Raw(activityJson)'
         data-admin-turnover='@Html.Raw(turnoverJson)'>
    <div class="page-head">
        <div>
            <span class="page-head__eyebrow">Admin Desk</span>
            <h1>Command center</h1>
            <p>Watch customer activity, liquidity and desk performance from a cleaner operational view.</p>
        </div>
        <div class="dashboard-card__actions">
            <form asp-action="GetPDF" method="post">
                <input type="hidden" name="GridHtml" />
                <button type="submit" class="app-btn app-btn--ghost" id="btnSubmit">Export PDF</button>
            </form>
        </div>
    </div>

    <div id="Grid">
        <div class="hero-stat-grid hero-stat-grid--dashboard">
            <article class="hero-stat">
                <span class="hero-stat__label">Client accounts</span>
                <strong class="hero-stat__value">@Model.UserAccounts</strong>
                <span class="hero-stat__hint">@Model.UserEmailConfirmed confirmed email addresses.</span>
            </article>
            <article class="hero-stat">
                <span class="hero-stat__label">Monthly transactions</span>
                <strong class="hero-stat__value">@Model.MonthlyTransactions</strong>
                <span class="hero-stat__hint">@Model.DailyTransactions today, @Model.AnnualTransactions this year.</span>
            </article>
            <article class="hero-stat">
                <span class="hero-stat__label">Desk spread</span>
                <strong class="hero-stat__value">@Model.AverageSpread.ToString("0.0000")</strong>
                <span class="hero-stat__hint">Hottest currency: @(string.IsNullOrWhiteSpace(Model.HottestCurrencyCode) ? "No traffic yet" : $"{Model.HottestCurrencyCode} · {Model.HottestCurrencyTransactions} events").</span>
            </article>
        </div>

        <div class="workspace-grid workspace-grid--admin">
            <div class="workspace-main">
                <section class="dashboard-card dashboard-card--chart">
                    <div class="dashboard-card__head">
                        <div>
                            <span class="page-head__eyebrow">Ops View</span>
                            <h2>Monthly activity</h2>
                            <p>Six-month pulse check of how busy the exchange desk has been.</p>
                        </div>
                    </div>
                    <div class="history-panel">
                        <canvas class="history-panel__canvas" data-admin-activity-chart></canvas>
                    </div>
                </section>

                <section class="dashboard-card dashboard-card--chart">
                    <div class="dashboard-card__head">
                        <div>
                            <span class="page-head__eyebrow">Turnover Mix</span>
                            <h2>Most active currencies</h2>
                            <p>Volume grouped by currency to show where the desk is moving most.</p>
                        </div>
                    </div>
                    <div class="history-panel history-panel--compact">
                        <canvas class="history-panel__canvas" data-admin-turnover-chart></canvas>
                    </div>
                </section>

                <section class="dashboard-card">
                    <div class="dashboard-card__head">
                        <div>
                            <span class="page-head__eyebrow">Latest Flow</span>
                            <h2>Desk activity stream</h2>
                        </div>
                    </div>
                    @if (!Model.LatestTransactions.Any())
                    {
                        <p class="dashboard-card__empty-copy">No transactions yet. Activity will appear here as soon as the first client moves funds.</p>
                    }
                    else
                    {
                        <div class="activity-feed">
                            @foreach (var item in Model.LatestTransactions)
                            {
                                <article class="activity-row">
                                    <div class="activity-row__meta">
                                        <span class="activity-row__title">@item.Description · @item.CurrencyCode</span>
                                        <span class="activity-row__date">@item.DateOfTransaction.ToString("dd MMM yyyy, HH:mm")</span>
                                    </div>
                                    <div class="activity-row__amount">
                                        <strong>@item.Amount.ToString("0.##") @item.CurrencyCode</strong>
                                        <span>@(string.IsNullOrWhiteSpace(item.UserDisplayName) ? item.UserEmail : item.UserDisplayName)</span>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </section>
            </div>

            <aside class="workspace-sidebar">
                <section class="dashboard-card">
                    <div class="dashboard-card__head">
                        <div>
                            <span class="page-head__eyebrow">Liquidity</span>
                            <h2>Desk reserves</h2>
                        </div>
                    </div>
                    <div class="liquidity-stack">
                        @foreach (var item in Model.Liquidity)
                        {
                            <article class="liquidity-row">
                                <strong>@item.CurrencyCode</strong>
                                <span>@item.Value.ToString("0.##")</span>
                            </article>
                        }
                    </div>
                </section>

                <section class="dashboard-card">
                    <div class="dashboard-card__head">
                        <div>
                            <span class="page-head__eyebrow">Turnover Ranking</span>
                            <h2>Top currencies</h2>
                        </div>
                    </div>
                    <div class="alarm-stack">
                        @foreach (var item in Model.Turnovers)
                        {
                            <article class="alarm-row">
                                <div class="alarm-row__head">
                                    <strong>@item.CurrencyCode</strong>
                                    <span>@item.Amount.ToString("0.##")</span>
                                </div>
                            </article>
                        }
                    </div>
                </section>
            </aside>
        </div>
    </div>
</section>
