@model VistulaExchange.Web.Models.HomeDashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Market Hub";
    var converterRates = JsonSerializer.Serialize(Model.Currencies.Select(c => new
    {
        code = c.ShortName,
        name = c.Name,
        country = c.Country,
        buy = c.BuyAt,
        sell = c.SellAt,
        spread = c.Spread
    }));
}

<section class="market-hero" data-converter-rates='@Html.Raw(converterRates)'>
    <div class="market-hero__copy">
        <span class="market-hero__eyebrow">Modern Currency Workspace</span>
        <h1>Trade desk clarity, without the spreadsheet energy.</h1>
        <p class="market-hero__lead">
            Monitor live exchange opportunities, simulate PLN conversions instantly and jump into the next action
            whether you run the desk or trade from your wallet.
        </p>

        <div class="hero-actions">
            @if (Model.IsAdmin)
            {
                <a class="app-btn app-btn--primary" asp-controller="ExchangeOfficeBoard" asp-action="Index">Open trading desk</a>
                <a class="app-btn app-btn--ghost" asp-controller="AdminReport" asp-action="Index">See desk report</a>
            }
            else if (Model.IsAuthenticated)
            {
                <a class="app-btn app-btn--primary" asp-controller="UserExchangeOfficeBoard" asp-action="Index">Start exchange</a>
                <a class="app-btn app-btn--ghost" asp-controller="UserAlarm" asp-action="Index">Manage alerts</a>
            }
            else
            {
                <a class="app-btn app-btn--primary" asp-area="Identity" asp-page="/Account/Login">Enter the desk</a>
                <a class="app-btn app-btn--ghost" asp-area="Identity" asp-page="/Account/Register">Create account</a>
            }
        </div>

        <div class="hero-stat-grid">
            <article class="hero-stat">
                <span class="hero-stat__label">Pairs in focus</span>
                <strong class="hero-stat__value">@Model.Currencies.Count</strong>
                <span class="hero-stat__hint">Live trading opportunities against PLN</span>
            </article>
            <article class="hero-stat">
                <span class="hero-stat__label">Average spread</span>
                <strong class="hero-stat__value">@Model.AverageSpread.ToString("0.0000")</strong>
                <span class="hero-stat__hint">Instant market read across the current board</span>
            </article>
            <article class="hero-stat">
                <span class="hero-stat__label">Desk mode</span>
                <strong class="hero-stat__value">@(Model.IsAdmin ? "Admin" : Model.IsAuthenticated ? "Client" : "Guest")</strong>
                <span class="hero-stat__hint">@(string.IsNullOrWhiteSpace(Model.UserDisplayName) ? "Preview the workspace before signing in." : $"Welcome back, {Model.UserDisplayName}.")</span>
            </article>
        </div>
    </div>

    <aside class="converter-panel">
        <div class="converter-panel__header">
            <span class="converter-panel__eyebrow">Quick Quote</span>
            <h2>Simulate a deal in seconds</h2>
        </div>

        <label class="converter-field">
            <span>Budget in PLN</span>
            <input type="number" min="0" step="0.01" value="1000" data-converter-amount />
        </label>

        <label class="converter-field">
            <span>Target currency</span>
            <select data-converter-code>
                @foreach (var currency in Model.Currencies)
                {
                    <option value="@currency.ShortName">@currency.ShortName · @currency.Name</option>
                }
            </select>
        </label>

        <div class="converter-result">
            <span class="converter-result__label">Estimated receive amount</span>
            <div class="converter-result__value">
                <strong data-converter-result-amount>0.00</strong>
                <span data-converter-result-code>EUR</span>
            </div>
        </div>

        <dl class="converter-details">
            <div>
                <dt>Buy rate</dt>
                <dd data-converter-rate>0.0000</dd>
            </div>
            <div>
                <dt>Spread</dt>
                <dd data-converter-spread>0.0000</dd>
            </div>
            <div>
                <dt>Market</dt>
                <dd data-converter-country>Europe</dd>
            </div>
        </dl>

        <p class="converter-note" data-converter-note>
            The converter uses the active board rates from the desk.
        </p>
    </aside>
</section>

<section class="insight-strip">
    <article class="insight-card">
        <span class="insight-card__eyebrow">Best Buy Entry</span>
        <h3>@Model.BestBuyCurrency?.ShortName</h3>
        <p>@(Model.BestBuyCurrency is null ? "No market data available yet." : $"{Model.BestBuyCurrency.Name} at {Model.BestBuyCurrency.BuyAt:0.0000} PLN")</p>
    </article>
    <article class="insight-card">
        <span class="insight-card__eyebrow">Tightest Spread</span>
        <h3>@Model.TightestSpreadCurrency?.ShortName</h3>
        <p>@(Model.TightestSpreadCurrency is null ? "No spread data available yet." : $"{Model.TightestSpreadCurrency.Spread:0.0000} spread with a balanced desk profile")</p>
    </article>
    <article class="insight-card">
        <span class="insight-card__eyebrow">Strongest Sell Exit</span>
        <h3>@Model.BestSellCurrency?.ShortName</h3>
        <p>@(Model.BestSellCurrency is null ? "No sell data available yet." : $"{Model.BestSellCurrency.SellAt:0.0000} PLN on the active board")</p>
    </article>
</section>

<section class="market-section">
    <div class="page-head page-head--compact">
        <div>
            <span class="page-head__eyebrow">Market Snapshot</span>
            <h2>Spotlight currencies</h2>
            <p>The four fastest pairs to scan before moving into a trade or refreshing the desk.</p>
        </div>
        <a class="app-btn app-btn--ghost" asp-controller="@(Model.IsAdmin ? "ExchangeOfficeBoard" : "UserExchangeOfficeBoard")" asp-action="Index">Open full board</a>
    </div>

    <div class="market-board-grid market-board-grid--compact">
        @foreach (var currency in Model.SpotlightCurrencies)
        {
            <article class="market-card market-card--spotlight">
                <div class="market-card__top">
                    <div>
                        <span class="market-card__code">@currency.ShortName</span>
                        <h3>@currency.Name</h3>
                        <p>@currency.Country</p>
                    </div>
                    <span class="market-chip">@currency.SpreadProfile</span>
                </div>
                <dl class="market-card__stats">
                    <div>
                        <dt>Buy</dt>
                        <dd>@currency.BuyAt.ToString("0.0000")</dd>
                    </div>
                    <div>
                        <dt>Sell</dt>
                        <dd>@currency.SellAt.ToString("0.0000")</dd>
                    </div>
                    <div>
                        <dt>Spread</dt>
                        <dd>@currency.Spread.ToString("0.0000")</dd>
                    </div>
                </dl>
            </article>
        }
    </div>
</section>

<section class="market-section">
    <div class="page-head page-head--compact">
        <div>
            <span class="page-head__eyebrow">Next Moves</span>
            <h2>Quick actions</h2>
            <p>Launch the next workflow without digging through the desk.</p>
        </div>
    </div>

    <div class="action-grid">
        @if (Model.IsAdmin)
        {
            <a class="action-card" asp-controller="ExchangeOfficeBoard" asp-action="Index">
                <span class="action-card__icon"><i class="bi bi-arrow-repeat"></i></span>
                <strong>Refresh and steer rates</strong>
                <p>Import, adjust and supervise the active trading board.</p>
            </a>
            <a class="action-card" asp-controller="MoneyStock" asp-action="Index">
                <span class="action-card__icon"><i class="bi bi-bank"></i></span>
                <strong>Control liquidity</strong>
                <p>Check desk stock before applying spread or approving trades.</p>
            </a>
            <a class="action-card" asp-controller="AdminTransactionHistory" asp-action="Index">
                <span class="action-card__icon"><i class="bi bi-journal-text"></i></span>
                <strong>Audit transactions</strong>
                <p>Review every move across the exchange office in one timeline.</p>
            </a>
        }
        else if (Model.IsAuthenticated)
        {
            <a class="action-card" asp-controller="UserExchangeOfficeBoard" asp-action="Index">
                <span class="action-card__icon"><i class="bi bi-currency-exchange"></i></span>
                <strong>Trade on the live board</strong>
                <p>Search for a pair, inspect spread and execute buy or sell instantly.</p>
            </a>
            <a class="action-card" asp-controller="UserDeposit" asp-action="Index">
                <span class="action-card__icon"><i class="bi bi-plus-circle"></i></span>
                <strong>Top up your wallet</strong>
                <p>Add balance in seconds and return to the exchange flow.</p>
            </a>
            <a class="action-card" asp-controller="UserAlarm" asp-action="Index">
                <span class="action-card__icon"><i class="bi bi-bell"></i></span>
                <strong>Set intelligent alerts</strong>
                <p>Let the desk notify you when a target rate is reached.</p>
            </a>
        }
        else
        {
            <a class="action-card" asp-area="Identity" asp-page="/Account/Login">
                <span class="action-card__icon"><i class="bi bi-box-arrow-in-right"></i></span>
                <strong>Sign in to trade</strong>
                <p>Unlock your wallet, personal alerts and full exchange workflows.</p>
            </a>
            <a class="action-card" asp-area="Identity" asp-page="/Account/Register">
                <span class="action-card__icon"><i class="bi bi-person-plus"></i></span>
                <strong>Create your desk access</strong>
                <p>Start with a fresh account and move from preview to real activity.</p>
            </a>
            <a class="action-card" asp-controller="Home" asp-action="Privacy">
                <span class="action-card__icon"><i class="bi bi-shield-check"></i></span>
                <strong>Explore with confidence</strong>
                <p>Review the app and get familiar with the workspace before logging in.</p>
            </a>
        }
    </div>
</section>
