@model VistulaExchange.Web.Models.CurrencyDetailsViewModel

@{
    ViewData["Title"] = $"{Model.ShortName} details";
}

<section class="workspace-shell"
         data-history-shell
         data-history-endpoint="@Url.Action("History", "UserExchangeOfficeBoard")"
         data-history-default="@Model.ShortName">
    <div class="page-head">
        <div>
            <span class="page-head__eyebrow">Currency Detail</span>
            <h1>@Model.ShortName market view</h1>
            <p>@Model.Name from @Model.Country with desk-ready buy and sell context.</p>
        </div>
        <div class="dashboard-card__actions">
            <a class="app-btn app-btn--ghost" asp-action="Index">Back to board</a>
            <a class="app-btn app-btn--primary" asp-action="Buy" asp-route-id="@Model.Id">Open buy quote</a>
            <a class="app-btn app-btn--ghost" asp-action="Sell" asp-route-id="@Model.Id">Open sell quote</a>
        </div>
    </div>

    <div class="hero-stat-grid hero-stat-grid--dashboard">
        <article class="hero-stat">
            <span class="hero-stat__label">Buy rate</span>
            <strong class="hero-stat__value">@Model.BuyAt.ToString("0.0000")</strong>
            <span class="hero-stat__hint">Desk price when you acquire @Model.ShortName.</span>
        </article>
        <article class="hero-stat">
            <span class="hero-stat__label">Sell rate</span>
            <strong class="hero-stat__value">@Model.SellAt.ToString("0.0000")</strong>
            <span class="hero-stat__hint">Desk price when you liquidate back into PLN.</span>
        </article>
        <article class="hero-stat">
            <span class="hero-stat__label">Spread</span>
            <strong class="hero-stat__value">@Model.Spread.ToString("0.0000")</strong>
            <span class="hero-stat__hint">Immediate read on entry versus exit cost.</span>
        </article>
    </div>

    <section class="dashboard-card dashboard-card--chart">
        <div class="dashboard-card__head">
            <div>
                <span class="page-head__eyebrow">History</span>
                <h2>7, 30 and 90 day trend</h2>
                <p>Switch windows to check how the pair has been behaving before the next trade.</p>
            </div>
            <div class="chart-toolbar">
                <input type="hidden" value="@Model.ShortName" data-history-code />
                <div class="segmented-control">
                    <button type="button" class="segmented-control__button" data-history-days="7">7D</button>
                    <button type="button" class="segmented-control__button is-active" data-history-days="30">30D</button>
                    <button type="button" class="segmented-control__button" data-history-days="90">90D</button>
                </div>
            </div>
        </div>
        <div class="history-panel">
            <canvas class="history-panel__canvas" data-history-chart></canvas>
        </div>
    </section>
</section>
