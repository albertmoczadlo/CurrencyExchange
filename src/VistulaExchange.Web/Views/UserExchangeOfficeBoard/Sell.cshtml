@model VistulaExchange.Web.Models.QuickExchangeViewModel

@{
    ViewData["Title"] = "Quick Sell";
}

<section class="trade-shell"
         data-quote-shell
         data-quote-mode="sell"
         data-quote-locked-until="@Model.QuoteLockedUntilUtc.ToString("O")">
    <div class="page-head">
        <div>
            <span class="page-head__eyebrow">Quick Exchange</span>
            <h1>Sell @Model.SourceCurrencyCode into PLN with a locked quote</h1>
            <p>Preview the exact payout, fee and desk liquidity before you execute the exchange.</p>
        </div>
        <div class="page-head__summary">
            <div class="page-pill">
                <span>@Model.SourceCurrencyCode balance</span>
                <strong>@Model.SourceBalance.ToString("0.####") @Model.SourceCurrencyCode</strong>
            </div>
            <div class="page-pill">
                <span>PLN desk liquidity</span>
                <strong>@Model.TargetLiquidityAvailable.ToString("0.00") PLN</strong>
            </div>
        </div>
    </div>

    <div class="trade-grid">
        <form asp-action="Sell" method="post" class="dashboard-card trade-form">
            <div class="dashboard-card__head">
                <div>
                    <span class="page-head__eyebrow">Quote Builder</span>
                    <h2>Choose sell amount</h2>
                </div>
                <div class="trade-lock @(Model.QuoteExpired ? "trade-lock--expired" : string.Empty)">
                    <i class="ri-timer-line"></i>
                    <span data-quote-countdown>30s left</span>
                </div>
            </div>

            <div class="trade-input-group">
                <label asp-for="RequestedAmount">You want to sell</label>
                <div class="trade-input-with-code">
                    <input asp-for="RequestedAmount"
                           type="number"
                           min="0"
                           max="@Model.MaxAmount"
                           step="0.0001"
                           class="form-control form-control-lg"
                           data-quote-amount />
                    <span>@Model.SourceCurrencyCode</span>
                </div>
                <small>Maximum available now: @Model.MaxAmount.ToString("0.####") @Model.SourceCurrencyCode</small>
            </div>

            <input asp-for="CurrencyId" type="hidden" />
            <input asp-for="CurrencyName" type="hidden" />
            <input asp-for="Mode" type="hidden" />
            <input asp-for="SourceCurrencyCode" type="hidden" />
            <input asp-for="TargetCurrencyCode" type="hidden" />
            <input asp-for="SourceBalance" type="hidden" />
            <input asp-for="TargetBalance" type="hidden" />
            <input asp-for="MaxAmount" type="hidden" />
            <input asp-for="Rate" type="hidden" data-quote-rate />
            <input asp-for="FeeRate" type="hidden" data-quote-fee-rate />
            <input asp-for="GrossValue" type="hidden" data-quote-gross-input />
            <input asp-for="FeeAmount" type="hidden" data-quote-fee-input />
            <input asp-for="NetValue" type="hidden" data-quote-net-input />
            <input asp-for="TargetLiquidityAvailable" type="hidden" />
            <input asp-for="QuoteLockedUntilUtc" type="hidden" />

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="trade-alert">
                    <i class="ri-error-warning-line"></i>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            <div class="trade-actions">
                <button type="submit" class="app-btn app-btn--primary" data-quote-submit>Confirm sell</button>
                <a class="app-btn app-btn--ghost" asp-action="Index">Back to board</a>
            </div>
        </form>

        <aside class="dashboard-card trade-summary">
            <div class="dashboard-card__head">
                <div>
                    <span class="page-head__eyebrow">Preview</span>
                    <h2>Payout forecast</h2>
                </div>
            </div>

            <dl class="trade-summary__stats">
                <div>
                    <dt>Locked rate</dt>
                    <dd data-quote-rate-output>@Model.Rate.ToString("0.0000")</dd>
                </div>
                <div>
                    <dt>Gross receive</dt>
                    <dd><span data-quote-gross>@Model.GrossValue.ToString("0.00")</span> PLN</dd>
                </div>
                <div>
                    <dt>Desk fee</dt>
                    <dd><span data-quote-fee>@Model.FeeAmount.ToString("0.00")</span> PLN</dd>
                </div>
                <div>
                    <dt>Net payout</dt>
                    <dd><span data-quote-net>@Model.NetValue.ToString("0.00")</span> PLN</dd>
                </div>
            </dl>

            <div class="trade-summary__foot">
                <p>Fee rate: @(Model.FeeRate * 100m).ToString("0.##")%</p>
                <p>Current PLN wallet balance: @Model.TargetBalance.ToString("0.00")</p>
            </div>
        </aside>
    </div>
</section>
